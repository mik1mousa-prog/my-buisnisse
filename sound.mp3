light:cm-light dark:cm-light flex h-full w-full flex-col items-stretch ͼk ͼy"><div class="cm-scroller"><div class="cm-content q9tKkq_readonly"><span class="ͼm">&lt;!DOCTYPE html&gt;</span><br><span class="ͼv">&lt;html</span><span> </span><span class="ͼu">lang</span><span class="ͼn">=</span><span class="ͼr">"ar"</span><span class="ͼv">&gt;</span><br><span class="ͼv">&lt;head&gt;</span><br><span class="ͼv">&lt;meta</span><span> </span><span class="ͼu">charset</span><span class="ͼn">=</span><span class="ͼr">"UTF-8"</span><span class="ͼv">&gt;</span><br><span class="ͼv">&lt;meta</span><span> </span><span class="ͼu">name</span><span class="ͼn">=</span><span class="ͼr">"viewport"</span><span> </span><span class="ͼu">content</span><span class="ͼn">=</span><span class="ͼr">"width=device-width, initial-scale=1.0"</span><span class="ͼv">&gt;</span><br><br><span class="ͼv">&lt;title&gt;</span><span>موقعي</span><span class="ͼv">&lt;/title&gt;</span><br><br><span class="ͼv">&lt;style&gt;</span><br><span class="ͼv">body</span><span> {</span><br><span>    margin: </span><span class="ͼq">0</span><span>;</span><br><span>    font-family: </span><span class="ͼq">Arial</span><span>;</span><br><span>    background: </span><span class="ͼn">linear-gradient</span><span>(</span><span class="ͼq">135</span><span class="ͼn">deg</span><span>, #0f172a, #1e293b);</span><br><span>    color: </span><span class="ͼq">white</span><span>;</span><br><span>    text-align: </span><span class="ͼq">center</span><span>;</span><br><span>}</span><br><br><span>.</span><span class="ͼs">container</span><span> {</span><br><span>    padding: </span><span class="ͼq">30</span><span class="ͼn">px</span><span>;</span><br><span>}</span><br><br><span class="ͼv">h1</span><span> {</span><br><span>    font-size: </span><span class="ͼq">40</span><span class="ͼn">px</span><span>;</span><br><span>    color: #38bdf8;</span><br><span>}</span><br><br><span class="ͼv">img</span><span> {</span><br><span>    width: </span><span class="ͼq">90</span><span class="ͼn">%</span><span>;</span><br><span>    max-width: </span><span class="ͼq">350</span><span class="ͼn">px</span><span>;</span><br><span>    border-radius: </span><span class="ͼq">20</span><span class="ͼn">px</span><span>;</span><br><span>    margin-top: </span><span class="ͼq">20</span><span class="ͼn">px</span><span>;</span><br><span>}</span><br><br><span class="ͼv">button</span><span> {</span><br><span>    margin-top: </span><span class="ͼq">25</span><span class="ͼn">px</span><span>;</span><br><span>    padding: </span><span class="ͼq">15</span><span class="ͼn">px</span><span> </span><span class="ͼq">30</span><span class="ͼn">px</span><span>;</span><br><span>    font-size: </span><span class="ͼq">20</span><span class="ͼn">px</span><span>;</span><br><span>    background: #38bdf8;</span><br><span>    border: </span><span class="ͼq">none</span><span>;</span><br><span>    border-radius: </span><span class="ͼq">12</span><span class="ͼn">px</span><span>;</span><br><span>    cursor: </span><span class="ͼq">pointer</span><span>;</span><br><span>}</span><br><br><span class="ͼv">button</span><span>:</span><span class="ͼs">hover</span><span> {</span><br><span>    background: #0ea5e9;</span><br><span>}</span><br><br><span>.</span><span class="ͼs">footer</span><span> {</span><br><span>    margin-top: </span><span class="ͼq">50</span><span class="ͼn">px</span><span>;</span><br><span>    font-size: </span><span class="ͼq">18</span><span class="ͼn">px</span><span>;</span><br><span>    opacity: </span><span class="ͼq">0.8</span><span>;</span><br><span>}</span><br><span class="ͼv">&lt;/style&gt;</span><br><span class="ͼv">&lt;/head&gt;</span><br><br><span class="ͼv">&lt;body&gt;</span><br><br><span class="ͼv">&lt;div</span><span> </span><span class="ͼu">class</span><span class="ͼn">=</span><span class="ͼr">"container"</span><span class="ͼv">&gt;</span><br><br><span class="ͼv">&lt;h1&gt;</span><span>مرحبا 👋</span><span class="ͼv">&lt;/h1&gt;</span><br><br><span class="ͼl">&lt;!-- الصورة --&gt;</span><br><span class="ͼv">&lt;img</span><span> </span><span class="ͼu">src</span><span class="ͼn">=</span><span class="ͼr">"https://files.catbox.moe/3b3t9u.jpg"</span><span> </span><span class="ͼu">alt</span><span class="ͼn">=</span><span class="ͼr">"صورتي"</span><span class="ͼv">&gt;</span><br><br><span class="ͼv">&lt;br&gt;</span><br><br><span class="ͼl">&lt;!-- زر الصوت --&gt;</span><br><span class="ͼv">&lt;button</span><span> </span><span class="ͼu">onclick</span><span class="ͼn">=</span><span class="ͼr">"</span><span class="ͼt">playSound</span><span>()</span><span class="ͼr">"</span><span class="ͼv">&gt;</span><span>🔊 اضغط للصوت</span><span class="ͼv">&lt;/button&gt;</span><br><br><span class="ͼl">&lt;!-- الصوت --&gt;</span><br><span class="ͼv">&lt;audio</span><span> </span><span class="ͼu">id</span><span class="ͼn">=</span><span class="ͼr">"sound"</span><span class="ͼv">&gt;</span><br><span>  </span><span class="ͼv">&lt;source</span><span> </span><span class="ͼu">src</span><span class="ͼn">=</span><span class="ͼr">"https://www.myinstants.com/media/sounds/go-go-gaga.mp3"</span><span> </span><span class="ͼu">type</span><span class="ͼn">=</span><span class="ͼr">"audio/mpeg"</span><span class="ͼv">&gt;</span><br><span class="ͼv">&lt;/audio&gt;</span><br><br><span class="ͼl">&lt;!-- الجملة --&gt;</span><br><span class="ͼv">&lt;div</span><span> </span><span class="ͼu">class</span><span class="ͼn">=</span><span class="ͼr">"footer"</span><span class="ͼv">&gt;</span><br><span>    الهدرة مواقع</span><br><span class="ͼv">&lt;/div&gt;</span><br><br><span class="ͼv">&lt;/div&gt;</span><br><br><span class="ͼv">&lt;script&gt;</span><br><span class="ͼn">function</span><span> </span><span class="ͼt">playSound</span><span>() {</span><br><span>    </span><span class="ͼt">document</span><span class="ͼn">.</span><span>getElementById(</span><span class="ͼr">"sound"</span><span>)</span><span class="ͼn">.</span><span>play();</span><br><span>}<