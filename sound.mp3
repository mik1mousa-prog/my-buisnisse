<ul data-start="911" data-end="960">
<li data-section-id="1s1xu38" data-start="911" data-end="928">
<p data-start="913" data-end="928">Extensions (🧩)</p>
</li>
<li data-section-id="pcr0nc" data-start="929" data-end="950">
<p data-start="931" data-end="950">ابحث: <code data-start="937" data-end="950">Live Server</code></p>
</li>
<li data-section-id="tr47xl" data-start="951" data-end="960">
<p data-start="953" data-end="960">Install</p>
</li>
</ul>
